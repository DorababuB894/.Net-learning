@model Category

<div class="container border p-3 ">
    <div class="row">
        <h1>Delete Category</h1>
        <hr />
    </div>
    @*@ <div asp-validation-summary="ModelOnly"></div>*@

    <form asp-action="Delete" method="post">
        <input asp-for="CategoryId" hidden />

        <div class="row p-3 mb-3">
            <label asp-for="Name"></label>
            <input asp-for="Name" type="text" disabled class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="row p-3 mb-3">
            <label asp-for="DisplayOrder"></label>
            <input asp-for="DisplayOrder" type="text" disabled class="form-control" />
            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
        </div>
        <div class="row p-3 mb-3">
            <label asp-for="Description"></label>
            <input asp-for="Description" type="text" disabled class="form-control" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="row p-3 ">
            <div class="col-6 col-md-3"><button class="btn btn-primary form-control">Delete</button></div>
            <div class="col-6 col-md-3"><a asp-controller="Category" asp-action="index" class="btn btn-secondary form-control">Back To List</a></div>

        </div>

    </form>
</div>


